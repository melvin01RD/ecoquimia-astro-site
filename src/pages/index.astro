---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { services } from "../data/services";
import ServiceCard from "../components/ServiceCard.astro";
import { Shield, Clock, Award, CheckCircle2 } from "@lucide/astro";

export const prerender = true;
---

<Base title="Ecoquimia - Control de Plagas y Fumigación en Santo Domingo" description="Servicios profesionales de fumigación y control de plagas en República Dominicana.">
  <Header slot="header" />

  <!-- HERO Banner con CTA -->
  <section class="hero-banner min-h-[300px] sm:min-h-[420px] md:min-h-[540px]">
    <img
      src="/banner-principal.jpg"
      alt="Control de plagas profesional - Ecoquimia"
      loading="eager"
      decoding="async"
      fetchpriority="high"
      style="position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/50 to-black/10 flex flex-col">
      <!-- Aviso de cambio de dominio (cerrable) -->
      <div id="domain-banner" class="bg-emerald-900/95 text-emerald-50 text-sm">
        <div class="container-max relative flex items-center justify-center gap-2 py-2 pr-10 text-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <span>Pronto estaremos en <strong class="text-emerald-300">www.fumigadoraecoquimia.com.do</strong></span>
          <button
            type="button"
            aria-label="Cerrar aviso"
            onclick="document.getElementById('domain-banner').style.display='none'"
            class="absolute right-3 top-1/2 -translate-y-1/2 text-emerald-300 hover:text-white p-1"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
          </button>
        </div>
      </div>

      <!-- Contenido del hero -->
      <div class="flex-1 flex flex-col justify-center sm:justify-end">
        <div class="container-max py-8 sm:pb-12">
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white leading-tight max-w-2xl">
            Control profesional de plagas en Santo Domingo
          </h1>
          <p class="mt-3 max-w-xl text-base md:text-lg text-white/90">
            Soluciones efectivas, seguras y certificadas para hogares y negocios en toda la República Dominicana.
          </p>
          <div class="mt-6">
            <a href="/cotizacion" class="btn btn-primary text-base px-7 py-3 shadow-lg">Cotizar ahora</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECCION DE CONFIANZA -->
  <section class="container-max pb-10">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-xl border border-zinc-200 bg-white p-4 flex items-center gap-3 transition hover:shadow-md">
        <div class="rounded-full bg-emerald-100 p-2 shrink-0">
          <Shield class="w-5 h-5 text-emerald-600" />
        </div>
        <div>
          <p class="font-semibold text-zinc-900">Productos certificados</p>
          <p class="text-sm text-zinc-600">EPA y salud pública</p>
        </div>
      </div>

      <div class="rounded-xl border border-zinc-200 bg-white p-4 flex items-center gap-3 transition hover:shadow-md">
        <div class="rounded-full bg-blue-100 p-2 shrink-0">
          <Clock class="w-5 h-5 text-blue-600" />
        </div>
        <div>
          <p class="font-semibold text-zinc-900">Respuesta rápida</p>
          <p class="text-sm text-zinc-600">En menos de 24 horas</p>
        </div>
      </div>

      <div class="rounded-xl border border-zinc-200 bg-white p-4 flex items-center gap-3 transition hover:shadow-md">
        <div class="rounded-full bg-amber-100 p-2 shrink-0">
          <Award class="w-5 h-5 text-amber-600" />
        </div>
        <div>
          <p class="font-semibold text-zinc-900">+10 años de experiencia</p>
          <p class="text-sm text-zinc-600">Personal capacitado</p>
        </div>
      </div>

      <div class="rounded-xl border border-zinc-200 bg-white p-4 flex items-center gap-3 transition hover:shadow-md">
        <div class="rounded-full bg-purple-100 p-2 shrink-0">
          <CheckCircle2 class="w-5 h-5 text-purple-600" />
        </div>
        <div>
          <p class="font-semibold text-zinc-900">Garantía por escrito</p>
          <p class="text-sm text-zinc-600">En todos los servicios</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICIOS -->
  <section class="container-max py-16" aria-labelledby="srv-title">
    <div class="text-center">
      <h2 id="srv-title" class="text-2xl md:text-3xl font-bold text-zinc-900">Nuestros servicios</h2>
      <div class="mx-auto mt-3 h-1.5 w-20 rounded-full bg-brand"></div>
      <p class="mt-3 text-zinc-600">Planes residenciales y comerciales con certificación.</p>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((s) => <ServiceCard service={s} />)}
    </div>

    <!-- CTA despues de servicios -->
    <div class="mt-10 text-center">
      <a href="/cotizacion" class="btn btn-primary">Cotizar ahora</a>
    </div>
  </section>

  <!-- APRENDE DE LAS PLAGAS -->
  <section class="container-max pb-16">
    <div class="rounded-3xl border border-black/5 bg-gradient-to-br from-emerald-50 to-white p-6 md:p-8">
      <h3 class="text-xl md:text-2xl font-semibold text-zinc-900">Aprende de las plagas</h3>
      <p class="mt-2 text-zinc-700">Consejos prácticos y guías rápidas para tu hogar o negocio.</p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/aprende-de-las-plagas" class="btn btn-primary" data-astro-prefetch>Guias y consejos</a>
        <a href="/contact" class="btn btn-outline" data-astro-prefetch>Contacto</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Base>
